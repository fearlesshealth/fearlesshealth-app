# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hospital_db
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Stellar (Testnet)
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC=https://soroban-testnet.stellar.org

# Hospital's Stellar account (generated on setup)
HOSPITAL_STELLAR_SECRET=your_hospital_stellar_secret_key
HOSPITAL_STELLAR_PUBLIC=your_hospital_stellar_public_key
